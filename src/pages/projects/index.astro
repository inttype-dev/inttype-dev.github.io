---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';

const allProjectEntries = await getCollection('projects');
const allPostEntries = await getCollection('posts');

const parseDate = (d: string) => new Date(d.length === 7 ? `${d}-01` : d);
const sortDate = (p: typeof allProjectEntries[0]) => parseDate(p.data.endDate ?? p.data.startDate);

const krProjects = allProjectEntries
  .filter(p => p.data.lang !== 'en' && !!p.data.name)
  .sort((a, b) => sortDate(b).valueOf() - sortDate(a).valueOf());

const enProjectMap = Object.fromEntries(
  allProjectEntries
    .filter(p => p.data.lang === 'en' && p.data.translationOf)
    .map(p => [p.data.translationOf!, p])
);

const postsByProject = krProjects.map(project => {
  const folder = project.id.split('/')[0];
  return {
    project,
    enProject: enProjectMap[project.id],
    posts: allPostEntries
      .filter(p => !p.data.draft && p.data.lang !== 'en' && p.id.startsWith(folder + '/'))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
  };
});
---

<Layout title="프로젝트 | inttype">
  <Header />
  <main style="max-width:1080px;margin:0 auto;padding:0 1.5rem;">

    <section style="padding:3.5rem 0 2rem;border-bottom:1px solid var(--border);">
      <h1 style="font-size:1.6rem;font-weight:700;color:var(--fg);margin-bottom:0.4rem;">
        <span class="nav-kr">프로젝트</span><span class="nav-en">Projects</span>
      </h1>
      <p style="font-size:0.9rem;color:var(--muted);">
        <span class="nav-kr">{krProjects.length}개의 프로젝트</span>
        <span class="nav-en">{krProjects.length} projects</span>
      </p>
    </section>

    <div style="padding-bottom:3rem;">
      {postsByProject.map(({ project, enProject, posts }, idx) => (
        <div class="project-group" style="border-bottom:1px solid var(--border);">

          <button class="project-row" data-idx={idx} aria-expanded="false">
            <!-- 썸네일 -->
            <div class="proj-thumb">
              {project.data.image
                ? <img src={project.data.image} alt={project.data.name} loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;" />
                : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:1.6rem;font-weight:700;color:var(--muted);">{project.data.name[0]}</div>
              }
            </div>

            <!-- 정보 -->
            <div style="flex:1;min-width:0;display:flex;flex-direction:column;justify-content:space-between;gap:0.5rem;text-align:left;">
              <div>
                <div style="display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap;margin-bottom:0.35rem;">
                  <span class={`proj-name${enProject ? ' nav-kr' : ''}`}>{project.data.name}</span>
                  {enProject && <span class="proj-name nav-en">{enProject.data.name}</span>}
                  <span style={`font-size:0.7rem;padding:0.18rem 0.5rem;border-radius:999px;background:${project.data.status === '진행 중' ? 'rgba(37,99,235,0.12)' : 'var(--border)'};color:${project.data.status === '진행 중' ? 'var(--accent)' : 'var(--muted)'};`}>
                    <span class="nav-kr">{project.data.status}</span>
                    <span class="nav-en">{project.data.status === '진행 중' ? 'In Progress' : 'Completed'}</span>
                  </span>
                </div>
                <p class={enProject ? 'lang-kr' : undefined} style="font-size:0.85rem;color:var(--muted);line-height:1.5;">{project.data.desc}</p>
                {enProject && <p class="lang-en" style="font-size:0.85rem;color:var(--muted);line-height:1.5;">{enProject.data.desc}</p>}
              </div>
              <div class="tag-row" data-tags-row>
                {project.data.tags.map(tag => (
                  <span class="proj-tag">{tag}</span>
                ))}
              </div>
            </div>

            <!-- 우측: 버튼들 + 글 수 + chevron -->
            <div class="proj-actions">
              <a
                href={`/projects/${project.data.slug ?? project.id}`}
                class="github-btn"
                onclick="event.stopPropagation()"
              >
                <span class="nav-kr">상세보기</span><span class="nav-en">Detail</span>
              </a>
              {project.data.github && (
                <a
                  href={project.data.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="github-btn"
                  onclick="event.stopPropagation()"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                  GitHub
                </a>
              )}
              {project.data.link && (
                <a
                  href={project.data.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="github-btn"
                  onclick="event.stopPropagation()"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                  </svg>
                  Link
                </a>
              )}
              <div style="display:flex;align-items:center;justify-content:flex-end;gap:0.4rem;color:var(--muted);">
                <span class="nav-kr" style="font-size:0.75rem;">{posts.length}개</span>
                <span class="nav-en" style="font-size:0.75rem;">{posts.length}</span>
                <svg class="chevron" width="18" height="18" viewBox="0 0 16 16" fill="none">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
          </button>

          <!-- 하위 글 목록 -->
          <div class="post-drawer" data-drawer={idx}>
            {posts.length > 0 ? (
              <ul style="list-style:none;padding:0;margin:0;">
                {posts.map(post => (
                  <li>
                    <a href={`/posts/${post.id}`} class="sub-link">
                      <span class="sub-title">{post.data.title}</span>
                      <span style="font-size:0.78rem;color:var(--muted);white-space:nowrap;font-variant-numeric:tabular-nums;">
                        <span class="nav-kr">{post.data.pubDate.toLocaleDateString('ko-KR', { year:'numeric', month:'2-digit', day:'2-digit' })}</span>
                        <span class="nav-en">{post.data.pubDate.toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}</span>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <p style="padding:0.6rem 0 0.75rem 1rem;font-size:0.85rem;color:var(--muted);">
                <span class="nav-kr">아직 관련 글이 없습니다.</span>
                <span class="nav-en">No posts yet.</span>
              </p>
            )}
          </div>

        </div>
      ))}
    </div>

  </main>
</Layout>

<style>
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    overflow: hidden;
    max-height: 1.6rem;
  }
  .proj-tag {
    font-size: 0.75rem;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.15rem 0.45rem;
    white-space: nowrap;
  }
  :global(.proj-tag-more) {
    font-size: 0.75rem;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.15rem 0.45rem;
    white-space: nowrap;
  }

  .project-row {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: opacity 0.15s;
  }
  .project-row:hover .proj-name { color: var(--accent); }
  .project-row[aria-expanded="true"] .chevron { transform: rotate(180deg); }

  .proj-thumb {
    flex-shrink: 0;
    width: 180px;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--card);
  }

  .chevron { transition: transform 0.2s ease; }

  .proj-actions {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.6rem;
    width: 90px;
  }

  .github-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.78rem;
    color: var(--muted);
    text-decoration: none;
    background: var(--card);
    font-family: var(--font-sans);
    transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .github-btn:hover { border-color: var(--accent); color: var(--accent); }

  .post-drawer {
    display: none;
    padding-left: calc(180px + 1.25rem);
    padding-bottom: 0.75rem;
  }

  .proj-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--fg);
    transition: color 0.15s;
  }
  .sub-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.65rem 0;
    border-top: 1px solid var(--border);
    text-decoration: none;
    gap: 1rem;
  }
  .sub-title {
    font-size: 0.875rem;
    color: var(--fg);
    transition: color 0.15s;
  }
  .sub-link:hover .sub-title { color: var(--accent); }

  @media (max-width: 640px) {
    .project-row { flex-direction: column; align-items: flex-start; gap: 0.85rem; }
    .proj-thumb { width: 100%; aspect-ratio: 16 / 9; }
    .proj-actions { width: 100%; flex-direction: row; flex-wrap: wrap; }
    .post-drawer { padding-left: 0; }
    .github-btn { min-height: 44px; flex: 1; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.project-row').forEach(row => {
    row.addEventListener('click', () => {
      const idx = row.dataset.idx!;
      const drawer = document.querySelector<HTMLDivElement>(`.post-drawer[data-drawer="${idx}"]`)!;
      const isOpen = row.getAttribute('aria-expanded') === 'true';
      row.setAttribute('aria-expanded', String(!isOpen));
      drawer.style.display = isOpen ? 'none' : 'block';
    });
  });

  function truncateTags(container: HTMLElement) {
    const tags = Array.from(container.querySelectorAll<HTMLElement>('.proj-tag:not(.proj-tag-more)'));
    if (tags.length < 2) return;

    // 기존 +N 뱃지 제거 및 태그 복원
    container.querySelector('.proj-tag-more')?.remove();
    tags.forEach(t => (t.style.display = ''));

    const firstTop = tags[0].getBoundingClientRect().top;
    const overflowIdx = tags.findIndex((t, i) => i > 0 && t.getBoundingClientRect().top > firstTop + 2);
    if (overflowIdx === -1) return;

    for (let i = overflowIdx; i < tags.length; i++) tags[i].style.display = 'none';

    let hiddenCount = tags.length - overflowIdx;
    const badge = document.createElement('span');
    badge.className = 'proj-tag-more';
    badge.textContent = `+${hiddenCount}`;
    container.appendChild(badge);

    // 뱃지도 넘치면 앞 태그 하나 더 숨김
    if (badge.getBoundingClientRect().top > firstTop + 2 && overflowIdx > 0) {
      tags[overflowIdx - 1].style.display = 'none';
      badge.textContent = `+${++hiddenCount}`;
    }
  }

  const tagRows = document.querySelectorAll<HTMLElement>('[data-tags-row]');
  tagRows.forEach(truncateTags);

  const ro = new ResizeObserver(() => tagRows.forEach(truncateTags));
  ro.observe(document.body);
</script>
