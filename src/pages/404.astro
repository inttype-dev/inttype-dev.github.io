---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
---

<Layout title="404 | inttype" description="페이지를 찾을 수 없습니다." noindex={true}>
  <Header />
  <main style="max-width:1080px;margin:0 auto;padding:0 1.5rem;">
    <section style="padding:6rem 0;display:flex;flex-direction:column;align-items:flex-start;gap:1.25rem;">
      <p style="font-size:clamp(3rem,10vw,6rem);font-weight:800;color:var(--accent);line-height:1;letter-spacing:-0.03em;">404</p>
      <h1 style="font-size:clamp(1.25rem,4vw,1.6rem);font-weight:700;color:var(--fg);line-height:1.3;">
        <span class="nav-kr">페이지를 찾을 수 없어요.</span>
        <span class="nav-en">Page not found.</span>
      </h1>
      <p style="font-size:0.975rem;color:var(--muted);line-height:1.7;">
        <span class="nav-kr">주소가 잘못되었거나 삭제된 페이지입니다.</span>
        <span class="nav-en">The page you're looking for doesn't exist or has been moved.</span>
      </p>
      <a href="/" style="margin-top:0.5rem;background:var(--accent);color:#fff;padding:0.6rem 1.25rem;border-radius:6px;font-size:0.9rem;font-weight:500;text-decoration:none;">
        <span class="nav-kr">홈으로</span>
        <span class="nav-en">Go Home</span>
      </a>
    </section>
  </main>
</Layout>
