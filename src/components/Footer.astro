---
---

<footer>
  <div class="footer-inner">
    <span class="footer-copy">© {new Date().getFullYear()} inttype</span>
    <a href="/rss.xml" class="rss-link" aria-label="RSS">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
      </svg>
      RSS
    </a>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    margin-top: auto;
  }
  .footer-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .footer-copy {
    font-size: 0.8rem;
    color: var(--muted);
  }
  .rss-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .rss-link:hover { color: var(--accent); }

  @media (max-width: 640px) {
    .footer-inner { flex-direction: column; align-items: flex-start; gap: 0.5rem; padding: 1.25rem 1.5rem; }
  }
</style>
